    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#i">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#r">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description>
        <rdfs:comment xml:lang="en">If a device has risk class III, then it is inferred as a high risk device.</rdfs:comment>
        <rdfs:label xml:lang="en">Rule 1 - Class III devices are high risk devices</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Device"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#d"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasRiskClass"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#d"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#RiskClass_III"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#HighRiskDevice"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#d"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <rdfs:comment xml:lang="en">If an incident is related to a critical risk, it is inferred as a high priority incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Rule 3 - Critical risks generate high priority incidents</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Incident"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#i"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#relatedToRisk"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#i"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#r"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#CriticalRisk"/>
                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#r"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#HighPriorityIncident"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#i"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <rdfs:comment xml:lang="en">If a device has a manufacturer, the inverse manufacturing relation can be inferred.</rdfs:comment>
        <rdfs:label xml:lang="en">Rule 2 - Manufacturers manufacture their devices</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Device"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#d"/>
