    </owl:Class>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Incident -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Incident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#relatedToDevice"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Device"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#relatedToRisk"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Represents an incident notified for a specific medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


