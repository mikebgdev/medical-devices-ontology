<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#"
     xml:base="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:ejercicio2="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2">
        <rdfs:comment xml:lang="en">OWL-DL ontology for high-risk medical devices and in vitro diagnostics based on the CSV files provided in the assignment.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical devices ontology for Exercise 2</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasCorrectiveAction -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasCorrectiveAction">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Incident"/>
        <rdfs:comment xml:lang="en">Links a corrective action to the incident that motivated it.</rdfs:comment>
        <rdfs:label xml:lang="en">has corrective action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasManufacturer">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Manufacturer"/>
        <rdfs:comment xml:lang="en">Links a device to its manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasRiskClass">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#RiskClass"/>
        <rdfs:comment xml:lang="en">Links a device to a regulatory risk class.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#linkedToIncident -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#linkedToIncident">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Incident"/>
        <rdfs:comment xml:lang="en">Links a corrective action to its related incident.</rdfs:comment>
        <rdfs:label xml:lang="en">linked to incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#manufacturesDevice -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#manufacturesDevice">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Device"/>
        <rdfs:comment xml:lang="en">Links a manufacturer to a device manufactured by it.</rdfs:comment>
        <rdfs:label xml:lang="en">manufactures device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#relatedToDevice -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#relatedToDevice">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Device"/>
        <rdfs:comment xml:lang="en">Links an incident to the affected device.</rdfs:comment>
        <rdfs:label xml:lang="en">related to device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#relatedToRisk -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#relatedToRisk">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Risk"/>
        <rdfs:comment xml:lang="en">Links an incident to the associated risk.</rdfs:comment>
        <rdfs:label xml:lang="en">related to risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#reportedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Manufacturer"/>
        <rdfs:comment xml:lang="en">Links an incident to the manufacturer that reported it.</rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasAuthorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasAuthorizationNumber">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the authorization number of a manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasCountry -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasCountry">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the country of a manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has country</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasDescription -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasDescription">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment xml:lang="en">Stores a textual description.</rdfs:comment>
        <rdfs:label xml:lang="en">has description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasEmail -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasEmail">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the contact email of a manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasEudamedReference -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasEudamedReference">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores a EUDAMED reference code.</rdfs:comment>
        <rdfs:label xml:lang="en">has EUDAMED reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasEventDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasEventDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Stores the event date of an incident.</rdfs:comment>
        <rdfs:label xml:lang="en">has event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasIntendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasIntendedPurpose">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the intended purpose of a device.</rdfs:comment>
        <rdfs:label xml:lang="en">has intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasName -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasName">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the name of an entity.</rdfs:comment>
        <rdfs:label xml:lang="en">has name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasOutcome -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasOutcome">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the outcome of an incident.</rdfs:comment>
        <rdfs:label xml:lang="en">has outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasProbability -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasProbability">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the probability level of a risk.</rdfs:comment>
        <rdfs:label xml:lang="en">has probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasReportDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasReportDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Stores the report date of an incident.</rdfs:comment>
        <rdfs:label xml:lang="en">has report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasSeverity -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasSeverity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the severity level of a risk.</rdfs:comment>
        <rdfs:label xml:lang="en">has severity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasStatus -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasStatus">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the status of a corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">has status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasUDI -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasUDI">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Stores the UDI-DI identifier of a device.</rdfs:comment>
        <rdfs:label xml:lang="en">has UDI-DI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#ActiveDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#DeviceType"/>
        <rdfs:comment xml:lang="en">Represents a device that depends on an energy source.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#ClassI -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#ClassI">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#RiskClass"/>
        <rdfs:comment xml:lang="en">Represents the lowest MDR risk class.</rdfs:comment>
        <rdfs:label xml:lang="en">Class I</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#ClassIII -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#ClassIII">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#RiskClass"/>
        <rdfs:comment xml:lang="en">Represents the highest MDR risk class.</rdfs:comment>
        <rdfs:label xml:lang="en">Class III</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#ClassIIa -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#ClassIIa">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#RiskClass"/>
        <rdfs:comment xml:lang="en">Represents MDR risk class IIa.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIa</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#ClassIIb -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#ClassIIb">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#RiskClass"/>
        <rdfs:comment xml:lang="en">Represents MDR risk class IIb.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIb</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#ClinicalRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#ClinicalRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#RiskType"/>
        <rdfs:comment xml:lang="en">Represents a clinical risk category.</rdfs:comment>
        <rdfs:label xml:lang="en">Clinical Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#CorrectiveAction -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#CorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasCorrectiveAction"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Incident"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Represents a field safety corrective action linked to an incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#CriticalRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#CriticalRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Risk"/>
        <rdfs:comment xml:lang="en">Represents a risk with critical severity.</rdfs:comment>
        <rdfs:label xml:lang="en">Critical Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Device -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Device">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasManufacturer"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#hasRiskClass"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#RiskClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#DeviceType -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#DeviceType">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#MedicalEntity"/>
        <rdfs:comment xml:lang="en">Represents a category of medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#HighPriorityIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#HighPriorityIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Incident"/>
        <rdfs:comment xml:lang="en">Represents an incident inferred as high priority.</rdfs:comment>
        <rdfs:label xml:lang="en">High Priority Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#HighRiskDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#HighRiskDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#Device"/>
        <rdfs:comment xml:lang="en">Represents a device inferred as high risk.</rdfs:comment>
        <rdfs:label xml:lang="en">High Risk Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#IVDDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#IVDDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/miki/ontologies/2026/3/ejercicio2.2#DeviceType"/>
        <rdfs:comment xml:lang="en">Represents an in vitro diagnostic device.</rdfs:comment>
